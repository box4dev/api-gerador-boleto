{
  "name": "api-gerador-boleto",
  "version": "1.0.0",
  "description": "API para geração de dados de boleto utilizando @box4dev/gerador-boleto",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --import tsx src/server.ts",
    "build": "tsup src/server.ts --format esm --dts",
    "start": "node --env-file=.env dist/server.js",
    "test": "node --import tsx --test --experimental-test-coverage test/**/*.test.ts",
    "test:unit": "node --import tsx --test test/unit/**/*.test.ts",
    "test:e2e": "node --import tsx --test test/e2e/**/*.test.ts",
    "test:watch": "node --import tsx --test --watch test/**/*.test.ts",
    "biome:format": "biome format --write ./src",
    "biome:lint": "biome lint --write ./src",
    "biome:check": "biome check --write ./src",
    "biome:ci": "biome ci ./src"
  },
  "keywords": [
    "boleto",
    "febraban",
    "api",
    "nodejs",
    "typescript"
  ],
  "author": "Box4Dev",
  "license": "MIT",
  "dependencies": {
    "@box4dev/gerador-boleto": "^1.0.1",
    "@hono/node-server": "^1.13.7",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "hono": "^4.6.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^20.6.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.0",
    "typescript": "^5.4.5",
    "wrangler": "^4.92.0"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.1.1",
      "onFail": "download"
    }
  },
  "pnpm": {
    "overrides": {
      "zod": "^3.23.8"
    }
  }
}